<odoo>
    <template id="s_odoo_partner" name="Odoo Partner">
        <section class="s_odoo_partner">
            <div class="s_odoo_partner_top bg-white text-center py-5">
                <div class="container">
                    <h2 class="partner_heading fw-bold mb-4">
                        Official and Trusted Partner for <span class="fw-bold">Odoo</span> In Sultanate of Oman
                    </h2>
                    <div class="odoo_logo_container mb-4">
                        <!-- Placeholder Odoo Logo -->
                        <img src="/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/odoo_logo/odoo_logo.png" style="height: 160px;" alt="Odoo Logo" class="img-fluid"/>
                    </div>
                    <a href="/contactus" class="btn btn-primary btn-contact-us d-inline-flex align-items-center justify-content-center px-4 py-2">
                        Contact us <i class="fa fa-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
            
            <div class="s_odoo_partner_bottom position-relative position-relative-wrapper">
                <div class="curve-separator">
                    <svg viewBox="0 0 1440 100" fill="none" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0,100 C480,0 960,0 1440,100 L1440,100 L0,100 Z" fill="#f4f5f6"/>
                    </svg>
                </div>
                <div class="bottom_content text-center pb-5 pt-3" style="background-color: #f4f5f6;">
                    <div class="container">
                        <div class="row g-4 justify-content-center icon-grid">
                            <t t-set="modules" t-value="[
                                {'name': 'Construction Builder', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/construction.svg'},
                                {'name': 'eLearning Platform', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/industry_elearning_platform.svg'},
                                {'name': 'Grocery Store', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/industry_grocery_store.svg'},
                                {'name': 'Website', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/website.svg'},
                                {'name': 'Inventory', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/stock.svg'},
                                {'name': 'Contacts', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/contacts.svg'},
                                {'name': 'Invoicing', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/account.svg'},
                                {'name': 'Accounting', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/account_accountant.svg'},
                                {'name': 'AI', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/ai.svg'},
                                {'name': 'Appointments', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/appointment.svg'},
                                {'name': 'Approvals', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/approvals.svg'},
                                {'name': 'Employees', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/hr.svg'},
                                {'name': 'Fleet', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/fleet.svg'},
                                {'name': 'CRM', 'image': '/wedo_custom_web_components/static/img/image_for_odoo_marketing_section/module_logos/crm.svg'}
                            ]"/>
                            <t t-foreach="modules" t-as="mod">
                                <div class="col-6 col-md-4 col-lg-special module-card-col">
                                    <div class="module-card rounded-4 shadow-sm bg-white p-2 d-flex flex-column align-items-center justify-content-center mx-auto mb-2" style="max-width: 100px; aspect-ratio: 1/1;">
                                        <div class="icon-container mb-2 d-flex align-items-center justify-content-center" style="min-height: 54px;">
                                            <t t-if="mod.get('image')">
                                                <img t-att-src="mod['image']" t-att-alt="mod['name']" style="max-height: 54px; max-width: 54px; object-fit: contain; border-radius: 4px;"/>
                                            </t>
                                            <t t-else="">
                                                <!-- Generic SVG Placeholder for modules -->
                                                <svg width="54" height="54" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <rect width="24" height="24" rx="6" fill="#DB161B" opacity="0.1"/>
                                                    <path d="M12 6L16 12H8L12 6Z" fill="#DB161B"/>
                                                    <circle cx="12" cy="16" r="2" fill="#DB161B"/>
                                                </svg>
                                            </t>
                                        </div>
                                    </div>
                                    <div class="module-name-wrapper mt-2">
                                        <span class="module-name text-muted fw-bold" style="font-size: 0.85rem;"><t t-esc="mod['name']"/></span>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="mt-5">
                            <p class="and_more_text fw-bold text-dark">and more +</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
