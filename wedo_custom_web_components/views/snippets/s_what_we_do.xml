                                    <img src="/wedo_custom_web_components/static/img/image_for_service_cards/svg/Camera-SVG.svg" alt="Camera Icon"/>
                                </div>
                            </div>
                            <div class="wedo-service-content p-4 text-start">
                                <h4 class="wedo-service-title fw-bold mb-3">CCTV &amp; Access Control</h4>
                                <p class="wedo-service-desc text-muted mb-0">We offer installation services for smart surveillance cameras and advanced fingerprint devices, with technical integration to ensure the security of your property and accurately track your employees attendance and departure times.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Card 2 -->
                    <div class="col-lg-4 mb-4">
