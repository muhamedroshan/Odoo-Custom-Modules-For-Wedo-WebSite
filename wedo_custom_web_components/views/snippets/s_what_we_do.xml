<odoo>
    <template id="s_what_we_do" name="What WeDo ?">
        <section class="s_what_we_do pt64 pb64 bg-white">
            <div class="container">
                <div class="row text-center mb-5 mt-4">
                    <div class="col-12">
                        <h2 class="display-3 fw-bold s_what_we_do_title">
                            What <span style="color: #E92E26;">We</span> <span style="color: #E92E26;">Do</span> ?
