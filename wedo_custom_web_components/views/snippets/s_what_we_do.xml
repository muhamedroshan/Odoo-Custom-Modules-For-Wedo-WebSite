                                <div class="wedo-service-img-container">
                                    <img src="/wedo_custom_web_components/static/img/image_for_service_cards/png/server-card-image.png" class="img-fluid w-100 wedo-service-img" alt="Networking And Computer Maintenance"/>
                                </div>
                                <div class="wedo-service-icon bg-white d-flex align-items-center justify-content-center">
                                    <img src="/wedo_custom_web_components/static/img/image_for_service_cards/svg/Server-SVG.svg" alt="Server Icon"/>
                                </div>
                            </div>
                            <div class="wedo-service-content p-4 text-start">
                                <h4 class="wedo-service-title fw-bold mb-3">Networking And Computer Maintenance</h4>
                                <p class="wedo-service-desc text-muted mb-0">We design and install high-speed servers and networks, and equip operations rooms with the highest security standards, we also provide computer maintenance and repair, troubleshooting, and system upgrades to ensure optimal performance and business continuity.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Card 3 -->
                    <div class="col-lg-4 mb-4">
                        <div class="wedo-service-card h-100 position-relative w-100 bg-white">
                            <div class="wedo-service-image-wrapper">
                                <div class="wedo-service-img-container">
                                    <img src="/wedo_custom_web_components/static/img/image_for_service_cards/png/odoo-service-card-image.png" class="img-fluid w-100 wedo-service-img" alt="Odoo ERP Solution"/>
